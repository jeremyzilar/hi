{
  "name": "hi",
  "version": "1.0.0",
  "description": "hi",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.0"
  },
  "dependencies": {},
  "devDependencies": {
    "tailwindcss": "^3.4.14",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "npm-run-all": "^4.1.5"
  },
  "scripts": {
    "build:css": "postcss assets/css/input.css -o assets/css/styles.css",
    "build:jekyll": "bundle exec jekyll build",
    "build": "npm-run-all build:css build:jekyll",
    "watch:css": "postcss assets/css/input.css -o assets/css/styles.css --watch",
    "watch:jekyll": "bundle exec jekyll serve --livereload",
    "dev": "npm-run-all --parallel watch:css watch:jekyll",
    "serve": "bundle exec jekyll serve --livereload",
    "clean": "bundle exec jekyll clean"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GSA/hi.git"
  },
  "keywords": [
    "hi",
    "jekyll",
    "uswds"
  ],
  "author": "jeremyzilar",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/GSA/hi/issues"
  },
  "homepage": "https://github.com/GSA/hi#readme"
}
